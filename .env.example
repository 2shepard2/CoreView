# Signage server HTTP listen port (container + host mapping in compose)
HOST_PORT=3210
PORT=3210
TZ=UTC

# MQTT broker details (optional bootstrap values; can be configured in onboarding)
MQTT_URL=
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=

# Topic root and wildcard subscription target
MQTT_TOPIC_ROOT=home/signage
MQTT_SUBSCRIBE_PATTERN=home/signage/+/cmd/+

# Optional CORS allow-list for browser dashboards (comma-separated origins)
CORS_ORIGINS=

# Optional Home Assistant API integration
HA_URL=
HA_TOKEN=

# Optional Frigate integration
FRIGATE_URL=
FRIGATE_MQTT_TOPIC=frigate/events

# Photo slideshow integration
IMMICH_URL=
IMMICH_API_KEY=
IMMICH_ALBUM_ID=

# First-run hardening
# Set for first bootstrap claim, then clear if you no longer want env-managed bootstrap.
COREVIEW_BOOTSTRAP_TOKEN=
# Enable when behind reverse proxy that sets X-Forwarded-Proto (recommended with TLS).
TRUST_PROXY=false
# Force Secure cookies even if proxy headers are missing.
FORCE_SECURE_COOKIES=false
